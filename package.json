{
  "name": "ours-privacy-adobe-tags-extension",
  "version": "1.0.0",
  "description": "Ours Privacy SDK extension for Adobe Experience Platform Tags",
  "scripts": {
    "dev": "npx @adobe/reactor-sandbox",
    "validate": "bash ./scripts/validate.sh",
    "package": "npx @adobe/reactor-packager",
    "test": "vitest",
    "test:ci": "vitest run --coverage --bail 1"
  },
  "devDependencies": {
    "@adobe/reactor-sandbox": "^13.4.0",
    "@adobe/reactor-validator": "^2.5.0",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0"
  }
}
